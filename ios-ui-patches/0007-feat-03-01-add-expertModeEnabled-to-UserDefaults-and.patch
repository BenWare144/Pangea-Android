+//
+//  About.swift
+//  Pangea
+//
+//  Copyright(c) Garth Vander Houwen 10/6/22.
+//
+import SwiftUI
+import StoreKit
+
+struct AboutPangea: View {
+
+	let locale = Locale.current
+
+	@State private var tapCount = 0
+	@State private var lastTapTime: Date = .distantPast
+	@State private var showToast = false
+	@State private var toastMessage = ""
+	@AppStorage("expertModeEnabled") private var expertModeEnabled = false
+
+	var body: some View {
+
+		VStack {
+			List {
+				Section(header: Text("What is Pangea?")) {
+					Text("An open source, off-grid, decentralized, mesh network that runs on affordable, low-power radios.")
+						.font(.title3)
+
+				}
+				Section(header: Text("Apple Apps")) {
+
+					if locale.region?.identifier ?? "US" == "US" {
+						HStack {
+							Image("SOLAR_NODE")
+								.resizable()
+								.aspectRatio(contentMode: .fit)
+								.frame(width: 75)
+								.cornerRadius(5)
+								.padding()
+							VStack(alignment: .leading) {
+								Link("Buy Complete Radios", destination: URL(string: "http://garthvh.com")!)
+									.font(.title2)
+								Text("Get custom waterproof solar and detection sensor router nodes, aluminium desktop nodes and rugged handsets.")
+									.font(.callout)
+							}
+						}
+					}
+					Link("Sponsor App Development", destination: URL(string: "https://github.com/sponsors/garthvh")!)
+						.font(.title2)
+					Link("GitHub Repository", destination: URL(string: "https://github.com/pangea/Pangea-Apple")!)
+						.font(.title2)
+					Button("Review the app") {
+						if let scene = UIApplication.shared.connectedScenes
+							.first(where: { $0.activationState == .foregroundActive }) as? UIWindowScene {
+							AppStore.requestReview(in: scene)
+						}
+					}
+					.font(.title2)
+
+					Text("Version: \(Bundle.main.appVersionLong) (\(Bundle.main.appBuild))")
+						.onTapGesture {
+							if Date().timeIntervalSince(lastTapTime) > 3 {
+								tapCount = 0
+							}
+							lastTapTime = Date()
+							tapCount += 1
+
+							if tapCount >= 7 {
+								expertModeEnabled.toggle()
+								tapCount = 0
+								UIImpactFeedbackGenerator(style: .medium).impactOccurred()
+								toastMessage = expertModeEnabled
+									? "Expert Mode Enabled -- full settings unlocked"
+									: "Expert Mode Disabled"
+								withAnimation {
+									showToast = true
+								}
+							} else if tapCount >= 4 {
+								toastMessage = "\(7 - tapCount) taps to expert mode"
+								withAnimation {
+									showToast = true
+								}
+							}
+						}
+				}
+
+				Section(header: Text("Project information")) {
+					Link("Website", destination: URL(string: "https://pangea.org")!)
+						.font(.title2)
+					Link("Documentation", destination: URL(string: "https://pangea.org/docs/getting-started")!)
+						.font(.title2)
+				}
+				Text("Pangea\u{00AE} Copyright Pangea LLC")
+					.font(.caption)
+			}
+		}
+		.toast(message: toastMessage, isPresented: $showToast)
+		.navigationTitle("About")
+		.navigationBarTitleDisplayMode(.inline)
+	}
+}
+
+// MARK: - Toast ViewModifier
+
+struct ToastModifier: ViewModifier {
+	let message: String
+	@Binding var isPresented: Bool
+
+	func body(content: Content) -> some View {
+		content
+			.overlay(alignment: .bottom) {
+				if isPresented {
+					Text(message)
+						.font(.subheadline)
+						.padding(.horizontal, 16)
+						.padding(.vertical, 10)
+						.background(.ultraThinMaterial, in: Capsule())
+						.padding(.bottom, 32)
+						.transition(.move(edge: .bottom).combined(with: .opacity))
+						.onAppear {
+							DispatchQueue.main.asyncAfter(deadline: .now() + 2.5) {
+								withAnimation {
+									isPresented = false
+								}
+							}
+						}
+						.id(message)
+				}
+			}
+			.animation(.easeInOut, value: isPresented)
+	}
+}
+
+extension View {
+	func toast(message: String, isPresented: Binding<Bool>) -> some View {
+		modifier(ToastModifier(message: message, isPresented: isPresented))
+	}
+}
